# SUBOTIZ_ENABLED = "true"
# CREEM_ENABLED = "false"

# PayPal (optional)
PAYPAL_ENABLED = "false"
PAYPAL_ENVIRONMENT = "sandbox"
PAYPAL_CLIENT_ID = ""
PAYPAL_CLIENT_SECRET = ""
PAYPAL_WEBHOOK_ID = ""

R2_SECRET_ACCESS_KEY = "xxx"
