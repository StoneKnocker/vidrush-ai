{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "content-collections build && CLOUDFLARE_ENV=prod react-router build",
    "dev": "CLOUDFLARE_ENV=dev react-router dev",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy --env prod",
    "deploy:version": "react-router build && wrangler versions upload",
    "deploy:promote": "wrangler versions deploy",
    "start": "wrangler dev --test-scheduled",
    "typegen": "CLOUDFLARE_ENV=prod wrangler types && react-router typegen",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "prepare": "lefthook install",
    "db:drop": "drizzle-kit drop",
    "db:generate": "drizzle-kit generate",
    "db:apply": "CLOUDFLARE_ENV=dev wrangler d1 migrations apply DB --local",
    "db:apply-prod": "CLOUDFLARE_ENV=prod wrangler d1 migrations apply DB --remote",
    "db:seed": "wrangler d1 execute DB --local --file=./app/lib/database/seed.sql",
    "db:seed-prod": "wrangler d1 execute DB --remote --file=./app/lib/database/seed.sql"
  },
  "dependencies": {
    "@conform-to/react": "^1.13.3",
    "@conform-to/zod": "^1.13.3",
    "@origin-space/image-cropper": "^0.1.9",
